{
  "type": "object",
  "required": [
    "input",
    "output",
    "interruption_class",
    "language",
    "category",
    "difficulty"
  ],
  "additionalProperties": false,
  "properties": {
    "input": {
      "type": "string",
      "minLength": 20,
      "pattern": "^Robot: \\\".+\\\" User: \\\".+\\\"$",
      "description": "Dialogue context only, exactly: Robot: \"...\" User: \"...\""
    },
    "output": {
      "type": "string",
      "minLength": 3,
      "pattern": "^(?!Robot:)(?!.*\\bPausing\\b)(?!.*\\bStopping\\b)(?!.*\\bCancelling\\b)(?!.*\\bContinuing\\b)(?!.*\\bRepeating\\b)(?!.*\\bAcknowledging\\b)(?!.*\\bChanging\\b)(?!.*\\bThe robot\\b).+",
      "description": "The robot's next spoken reply only. Do not include Robot: prefix. Do not write an action label or narration."
    },
    "interruption_class": {
      "type": "string",
      "enum": [
        "continue",
        "stop",
        "pause",
        "clarify_or_repeat",
        "change_or_correct"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "English",
        "French",
        "Arabic",
        "Darija",
        "Spanish",
        "German",
        "Italian",
        "Portuguese",
        "Dutch",
        "Japanese",
        "Korean",
        "Chinese",
        "Hindi"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "home_robot",
        "navigation",
        "object_handling",
        "safety",
        "conversation",
        "teaching",
        "reminder",
        "general"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard"
      ]
    }
  }
}
